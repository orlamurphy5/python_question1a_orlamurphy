        "import pandas as pd\n",
        "import numpy as np\n",
        "from scipy import stats\n",
        "\n",
        "df = pd.read_csv('ncbirths.csv')\n",
        "df['premature'] = (df['weeks'] < 37).astype(int)\n",
        "\n",
        "table = pd.crosstab(df['habit'], df['premature'], margins=True)\n",
        "props = pd.crosstab(df['habit'], df ['premature'], normalize='index')\n",
        "print(\"Dataset Shape:\", df.shape)\n",
        "\n",
        "print(\"------------\")\n",
        "print(table)\n",
        "print(\"\\n-------------\")\n",
        "print(props)\n",
        "\n",
        "# Extract numerical values from the 'table' DataFrame\n",
        "n_ns = table.loc['nonsmoker', 'All']\n",
        "x_ns = table.loc['nonsmoker', 1]\n",
        "n_s = table.loc['smoker', 'All']\n",
        "x_s = table.loc['smoker', 1]\n",
        "\n",
        "p_ns = x_ns / n_ns\n",
        "p_s = x_s / n_s\n",
        "\n",
        "diff = p_s - p_ns\n",
        "\n",
        "se_ci = np.sqrt((p_s*(1-p_s)/n_s) + (p_ns*(1-p_ns)/n_ns))\n",
        "lower, upper = diff - 1.96 * se_ci, diff + 1.96 * se_ci # Corrected upper bound calculation\n",
        "\n",
        "p_pool = (x_s + x_ns) / (n_s + n_ns)\n",
        "se_p = np.sqrt(p_pool * (1-p_pool) * (1/n_s + 1/n_ns))\n",
        "z = diff / se_p\n",
        "p_val = 2 * (1 - stats.norm.cdf(abs(z)))\n",
        "\n",
        "print(f\"\\n--- Results ---\")\n",
        "print(f\"95% Confidence Interval: ({lower:.4f}, {upper:.4f})\")\n",
        "print(f\"Z-score: {z:.4f}\")\n",
        "print(f\"P-value: {p_val:.4f}\")"
      ],
